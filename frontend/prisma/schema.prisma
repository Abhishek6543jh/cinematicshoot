datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  PHOTOGRAPHER
  ADMIN
  SUPER_ADMIN
  BOOKING_MANAGER
  CONTENT_MANAGER
  HR_MANAGER
  FINANCE_MANAGER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PackageType {
  PHOTOGRAPHY
  VIDEOGRAPHY
  HYBRID
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String?
  name         String
  role         Role       @default(CUSTOMER)
  phoneNumber  String?    @unique
  googleId     String?    @unique
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  profile      Profile?
  bookings     Booking[]  @relation("CustomerBookings")
  photographerBookings Booking[] @relation("PhotographerBookings")
  auditLogs    AuditLog[]
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  avatarUrl       String?
  portfolioImages String?  // Comma-separated S3 URLs
  experienceYears Int      @default(0)
  resumeUrl       String?  // For applicants/photographers
  rating          Float    @default(0.0)
  isApproved      Boolean  @default(false)
  dob             String?
  gender          String?
  address         String?
  city            String?
  state           String?
  country         String?
  indexPortfolio  Boolean  @default(true)
  shareAnalytics  Boolean  @default(false)
  emailNotifications Boolean @default(true)
  smsNotifications   Boolean @default(false)
  updatedAt       DateTime @updatedAt
}

model Package {
  id             String      @id @default(uuid())
  photographerId String
  name           String
  description    String
  price          Float
  durationMinutes Int
  type           PackageType @default(PHOTOGRAPHY)
  isCustom       Boolean     @default(false)
  isActive       Boolean     @default(true)
  category       String?
  includedServices String?   // JSON list of services
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  bookings       Booking[]
}

model Slot {
  id             String   @id @default(uuid())
  photographerId String
  date           DateTime // YYYY-MM-DD
  timeStart      DateTime // Timestamp
  timeEnd        DateTime // Timestamp
  isBooked       Boolean  @default(false)

  booking        Booking?
}

model Booking {
  id                  String        @id @default(uuid())
  customerId          String
  customer            User          @relation("CustomerBookings", fields: [customerId], references: [id])
  photographerId      String?
  photographer        User?         @relation("PhotographerBookings", fields: [photographerId], references: [id])
  packageId           String?
  package             Package?      @relation(fields: [packageId], references: [id])
  slotId              String?       @unique
  slot                Slot?         @relation(fields: [slotId], references: [id])
  status              BookingStatus @default(PENDING)
  totalPrice          Float
  invoiceUrl          String?
  notes               String?

  // Flat fields for frontend compatibility
  customerName        String?
  customerEmail       String?
  customerPhone       String?
  photographyCategory String?
  selectedPackage     String?
  eventDate           String?
  eventTime           String?
  location            String?
  specialRequirements String?
  paymentStatus       PaymentStatus @default(PENDING)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  payment             Payment?
  review              Review?
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  transactionId String        @unique
  provider      String        // "STRIPE" or "RAZORPAY"
  status        PaymentStatus @default(PENDING)
  amount        Float
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rating    Int      // 1 to 5
  comment   String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g. "USER_LOGIN", "CREATE_BOOKING", "PAYMENT_SUCCESS"
  details   String   // JSON text
  ipAddress String?
  createdAt DateTime @default(now())
}

enum JobStatus {
  OPEN
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
}

model Job {
  id           String             @id @default(uuid())
  title        String
  department   String
  location     String
  type         String             // "Full-time", "Part-time", "Contract"
  description  String
  requirements String
  status       JobStatus          @default(OPEN)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  applications JobApplication[]
}

model JobApplication {
  id          String            @id @default(uuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String
  bio         String
  resumeUrl   String
  status      ApplicationStatus @default(APPLIED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum GalleryCategory {
  WEDDING
  PRE_WEDDING
  BIRTHDAY
  CORPORATE
  FASHION
  PRODUCT_PHOTOGRAPHY
}

model Album {
  id          String          @id @default(uuid())
  title       String
  description String?
  category    GalleryCategory
  isFeatured  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  mediaItems  MediaItem[]
}

model MediaItem {
  id        String   @id @default(uuid())
  albumId   String
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  url       String
  type      String   // "IMAGE" or "VIDEO"
  createdAt DateTime @default(now())
}

model PromoCode {
  id        String   @id @default(uuid())
  code      String   @unique
  discount  Float    // Percentage
  isActive  Boolean  @default(true)
  expiry    DateTime
  createdAt DateTime @default(now())
}

model BlockedDate {
  id        String   @id @default(uuid())
  date      DateTime @unique // YYYY-MM-DD
  reason    String?
  createdAt DateTime @default(now())
}

model CmsContent {
  id        String   @id @default(uuid())
  section   String   @unique // "homepage", "about", etc.
  content   String   // JSON string content
  updatedAt DateTime @updatedAt
}
